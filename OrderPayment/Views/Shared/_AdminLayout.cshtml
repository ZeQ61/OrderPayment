<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin Paneli</title>
    <link rel="stylesheet" href="~/css/styles.css">
</head>
<body>
    <div class="admin-layout">
        <aside class="sidebar">
            <h1>Admin Paneli</h1>
            <nav>
                <ul>
                    <li><a href="@Url.Action("AdminPanel", "Admin")">Ana Sayfa</a></li>
                    <li><a href="@Url.Action("AddProduct", "Admin")">Ürün Ekle</a></li>
                </ul>
            </nav>
        </aside>
        <main class="content">
            @RenderBody() <!-- Sayfa içeriği buraya yüklenecek -->
        </main>
    </div>
    <script src="~/js/AdminPanelscript.js"></script>
</body>
</html>
