<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kullanıcı Oluştur</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7fc;
            color: #333;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            padding-top: 50px;
            padding-bottom: 50px;
        }

        .container {
            background-color: #fff;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 600px;
            box-sizing: border-box;
        }

        h2 {
            text-align: center;
            color: #4CAF50;
            margin-bottom: 20px;
        }

        label {
            font-weight: bold;
            margin-bottom: 8px;
            display: block;
        }

        input {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
            font-size: 14px;
        }

            input:focus {
                outline: none;
                border-color: #4CAF50;
            }

        button {
            width: 100%;
            padding: 14px;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

            button:hover {
                background-color: #45a049;
            }

        .error {
            color: red;
            font-size: 14px;
            margin-top: 10px;
        }

        .success {
            color: green;
            font-size: 14px;
            margin-top: 10px;
        }

        .message-container {
            margin-top: 20px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Yeni Kullanıcı Oluştur</h2>
        <form id="userForm">
            <label for="firstName">Ad:</label>
            <input type="text" id="firstName" name="firstName" required><br>

            <label for="lastName">Soyad:</label>
            <input type="text" id="lastName" name="lastName" required><br>

            <label for="email">E-posta:</label>
            <input type="email" id="email" name="email" required><br>

            <label for="password">Şifre:</label>
            <input type="password" id="password" name="password" required><br>

            <label for="phoneNumber">Telefon Numarası:</label>
            <input type="tel" id="phoneNumber" name="phoneNumber" pattern="^\+90\d{10}$" placeholder="+905336360079" required><br>

            <button type="submit">Kullanıcı Oluştur</button>
        </form>

        <div id="message" class="message-container"></div>
    </div>

    <script>
        document.getElementById("userForm").addEventListener("submit", async function (event) {
            event.preventDefault();

            const formData = {
                firstName: document.getElementById("firstName").value,
                lastName: document.getElementById("lastName").value,
                email: document.getElementById("email").value,
                passwordHash: document.getElementById("password").value,
                phoneNumber: document.getElementById("phoneNumber").value,
            };

            try {
                const response = await fetch("https://localhost:7297/api/user/create", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();  // JSON olarak almak

                const messageElement = document.getElementById("message");

                if (response.ok) {
                    messageElement.textContent = "Kullanıcı başarıyla oluşturuldu! Doğrulama kodu SMS ile gönderildi.";
                    messageElement.className = "success";
                    document.getElementById("userForm").reset();
                } else {
                    messageElement.textContent = result.Message || "Kullanıcı oluşturulurken bir hata oluştu.";
                    messageElement.className = "error";
                }
            } catch (error) {
                const messageElement = document.getElementById("message");
                messageElement.textContent = "Sunucuya bağlanırken bir hata oluştu: " + error.message;
                messageElement.className = "error";
            }
        });
    </script>
</body>
</html>
